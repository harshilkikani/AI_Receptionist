# ═══════════════════════════════════════════════════════════════════════
# AI Receptionist — environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (required for phone support) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# Default fallback on-call transfer number (overridden per client)
ON_CALL_NUMBER=

# ── Margin protection: global kill switch ─────────────────────────────
# When false, ALL new enforcement is bypassed regardless of individual flags.
# Use this to instantly disable everything without per-flag toggling.
MARGIN_PROTECTION_ENABLED=true

# ── Margin protection: individual enforcement flags ───────────────────
# All default to false (shadow mode) — they LOG what they'd do without
# actually enforcing. Flip to true per-feature during rollout.
ENFORCE_CALL_DURATION_CAP=false
ENFORCE_SPAM_FILTER=false
ENFORCE_SMS_CAP=false

# Alerts default to on because they're safe (notifications only).
ENFORCE_USAGE_ALERTS=true

# P3 — owner emergency SMS push. Default on (safe: pushes during real
# emergencies, informational only). Set to false for shadow mode during
# initial rollout. Respects MARGIN_PROTECTION_ENABLED kill switch.
ENFORCE_OWNER_EMERGENCY_SMS=true

# ── Admin dashboard (REQUIRED BEFORE PUBLIC EXPOSURE) ─────────────────
# /admin/* is read-only but still leaks per-client margin + recent caller
# phone numbers. Before exposing via cloudflared / ngrok / a real domain,
# SET BOTH of these. If either is unset, the admin is open — acceptable
# only for localhost operation.
#
#   ADMIN_USER=<pick any>
#   ADMIN_PASS=<32+ random chars>
ADMIN_USER=
ADMIN_PASS=

# Rate limit for /admin/* paths (per-IP, per-minute). Defaults to 60.
# Lower this on shared-IP deploys to blunt scraping.
ADMIN_RATE_LIMIT_PER_MIN=60

# ── Client portal (P1) ────────────────────────────────────────────────
# Signs per-client URLs at /client/{id}?t=<token>. Tokens never expire;
# rotate by changing this secret. MUST be set before minting any portal
# URL. Empty = portal disabled (all tokens rejected).
#
#   python -m src.client_portal issue <client_id>
#   → prints the portal URL for the client
CLIENT_PORTAL_SECRET=

# Public URL used when printing portal links. cloudflared sets this for you
# when running scripts/reclaim_tunnel.py (see P9). Default falls back to
# http://localhost:8765 which is fine for local issuing.
PUBLIC_BASE_URL=

# ── Alerting transport (optional) ─────────────────────────────────────
# Configure either SMTP or webhook in config/alerts.json, not here.
# These are ONLY for SMTP password if using email alerts.
ALERT_SMTP_PASSWORD=

# ── Development / debugging ───────────────────────────────────────────
LOG_LEVEL=info
